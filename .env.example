# 쇼츠공방(shorts-studio) 설정 — .env 로 복사해서 본인 경로로 채우세요. 모두 선택값.

# LLM: 영상공방류 OAuth 백엔드(services/llm_backend.py + venv)를 그 venv 로 브리지해 재사용.
#  - 그 백엔드 프로젝트 경로를 지정 (codex/agy CLI 가 로그인돼 있어야 AI 기능 동작)
SHORTS_VODSTUDIO_DIR=C:\path\to\your\vodstudio-project
# 공급자: codex(ChatGPT 로그인) | agy(Antigravity/Gemini 로그인)
LLM_PROVIDER=codex

# 번들(chNN_bundle)을 찾을 폴더들 (세미콜론 구분). 비우면 경로 직접 입력칸으로만 사용.
SHORTS_BUNDLE_ROOTS=C:\path\to\bundles\_assets;C:\path\to\another\data
